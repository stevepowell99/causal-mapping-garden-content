@article{ackermannOverlookedUnderusedBenefits2024,
  title = {Overlooked and Underused? {{The}} Benefits and Challenges of Using Causal Mapping for Project Studies},
  shorttitle = {Overlooked and Underused?},
  author = {Ackermann, Fran and Maytorena-Sanchez, Eunice},
  date = {2024-12},
  journaltitle = {Project Leadership and Society},
  volume = {5},
  pages = {100161},
  issn = {26667215},
  doi = {10.1016/j.plas.2024.100161},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S2666721524000462},
  urldate = {2024-12-05},
  abstract = {Despite the considerable body of extant research on project management complexities, further investigation of the actualities of practice, and the impact of projects on societies is required – but this is not easy. Research methods that enable researchers to surface, structure, and analyse the range of interacting issues, objectives, values, decisions, and options that constitute project complexities, in a way that provides richness and depth, are critical for advancing the field. This paper provides a synthesis of the literature on causal mapping applied in project studies and reflects on how causal mapping can provide a powerful data collection and analysis technique which can reveal valuable insights on project organising practice. The paper present how causal mapping has been used to support three data collection forms (desk-based, individual and group settings) commonly used in project studies, noting both the benefits and challenges before reflecting upon how it can be used in a complementary manner alongside other data collection approaches such as surveys, and methods such as case studies and action research. The paper concludes with some final comments along with noting potential research directions.},
  langid = {english},
  file = {C:\Users\Zoom\Zotero-cm\storage\IYKMCL8V\Ackermann and Maytorena-Sanchez - 2024 - Overlooked and underused The benefits and challenges of using causal mapping for project studies.pdf},
  keywords = {causal mapping, causal-mapping-biblio, causal-mapping-key-works-not-us}
}

@article{ackermannResearchingComplexProjects2016,
  title = {Researching Complex Projects: {{Using}} Causal Mapping to Take a Systems Perspective},
  author = {Ackermann, Fran and Alexander, James},
  date = {2016},
  journaltitle = {Int. J. Project Manage.},
  volume = {34},
  number = {6},
  pages = {891--901},
  issn = {0263-7863},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0263786316300072},
  urldate = {2021-03-10},
  abstract = {Extant literature has called for researchers to be more pluralistic in their approaches to researching projects. Responding to this call, this paper offers an exposition of a causal mapping technique. In the project management literature, there already exists a small number of articles reporting effective use of causal mapping. However, these are not dedicated to detailed explanation of the technique itself and so lack consideration of its features beyond those relevant to a particular application. Consequently, an exposition of the technique is needed to enable comprehensive understanding of causal mapping to be gained and its suitability for research designs assessed. Specifically, this paper examines causal mapping's theoretical grounding, explores its strengths and weakness, presents example applications, compares alternative causal mapping approaches, and overall, explains how causal mapping can support a systemic perspective on projects. These issues will be of interest to researchers who wish to incorporate causal mapping into their project management research designs.},
  issue = {6},
  file = {C:\Users\Zoom\Zotero-cm\storage\YP5C89UF\Ackermann_Alexander_2016_Researching complex projects.pdf},
  keywords = {causal mapping}
}

