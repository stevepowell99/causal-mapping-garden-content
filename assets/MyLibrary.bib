@online{daviesParEvoEnablingParticipatory2022,
  type = {SSRN Scholarly Paper},
  title = {{{ParEvo}}: {{Enabling}} the {{Participatory Exploration}} of {{Alternative Futures}}},
  shorttitle = {{{ParEvo}}},
  author = {Davies, Rick},
  date = {2022-10-29},
  number = {4261400},
  location = {Rochester, NY},
  doi = {10.2139/ssrn.4261400},
  url = {https://papers.ssrn.com/abstract=4261400},
  urldate = {2022-11-26},
  abstract = {ParEvo is an online method of developing alternative future scenarios or past histories, using a participatory evolutionary process (hence ParEvo). This involves the re-iteration of variation, selection, and reproduction i.e., an embodiment of the evolutionary algorithm (Campbell, 1960; Dennett, 1996). The process is designed to be used by multiple people, to produce a collective good – a set of storylines. In addition, the process generates data on the structure of participation – how people have collaborated to produce those storylines.For users, ParEvo.org can be used to achieve two related kinds of purposes. The first is cognitive: to enable participants to creatively think about alternative futures, and how they do that thinking (meta-cognition). The second is more behavioural: to prompt consideration of ways of responding to possible futures, in anticipation and/or in response, and to exploit and/or mitigate the consequences.This paper illustrates how a ParEvo exercise is implemented and analysed, along with an explanation of its origins and subsequent use. Illustrative references are made to two recent exercises carried out by the Centre for the Study of Existential Risk (CSER), in Cambridge, UK. Three types of evaluation challenges are highlighted, concerning the performance  of individual participants, specific exercises and the platform as a whole. Researchers in collective intelligence are invited to explore the uses of the application, and to address some of the challenges raised in this paper},
  issue = {4261400},
  langid = {english},
  pubstate = {prepublished},
  file = {C\:\\Users\\Zoom\\Zotero-cm\\storage\\C6FZ3EYL\\Davies_2022_ParEvo.pdf;C\:\\Users\\Zoom\\Zotero-cm\\storage\\SHFHWSW6\\papers.html},
