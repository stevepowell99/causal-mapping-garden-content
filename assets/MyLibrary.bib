@incollection{powellDoesOurTheory2023,
  title = {Does Our Theory Match Your Theory? {{Theories}} of Change and Causal Maps in {{Ghana}}},
  booktitle = {Strategic {{Thinking}}, {{Design}} and the {{Theory}} of {{Change}}. {{A Framework}} for {{Designing Impactful}} and {{Transformational Social Interventions}}},
  author = {Powell, Steve and Larquemin, Aurélie and Copestake, James and Remnant, Fiona and Avard, Rebekah},
  editor = {Simeone, Luca and Drabble, David and Morelli, Nicola and family=Götzen, given=Amalia, prefix=de, useprefix=true},
  date = {2023},
  publisher = {Edward Elgar},
  abstract = {What do the intended beneficiaries of an international development programme think about causes of poverty and empowerment? Do their perceptions match up with the theories of change constructed by organisations trying to support them? This case study looks at a project which has the goal of increasing the economic empowerment of women in Ghana, implemented by Opportunity International UK (OIUK), an NGO working in international development. A mid-term evaluation was carried out using the Qualitative Impact Protocol (QuIP) methodology to gather stories of change, and reasons for changes, directly from project participants. These stories were analysed and visualised using a web application called Causal Map. The first part of this chapter presents causal mapping as a group of methods with much to offer strategic thinking in evaluation. It explains how both theories of change on the one hand, and the type of evidence gathered for evaluations such as these on the other, can be understood as different types of causal map. The second part presents how the causal maps produced in the evaluation were used to answer evaluation questions, in particular by comparing the resulting causal maps with the project’s original theory of change. It also discussed some important differences revealed by this comparison and how it was used to enrich OIUK’s strategic thinking and update the theory of change for the next phase of the project.},
  file = {C:\Users\Zoom\Zotero-cm\storage\XEPC37NX\Powell et al_2023_Does our theory match your theory.pdf},
  keywords = {causal mapping, causal-mapping-biblio, causal-map-our-theory, !read-me}
}

