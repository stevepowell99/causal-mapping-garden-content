@article{drurySurveyExtractionApplications2022,
  title = {A Survey of the Extraction and Applications of Causal Relations},
  author = {Drury, Brett and Gonçalo Oliveira, Hugo and De Andrade Lopes, Alneu},
  date = {2022-05},
  journaltitle = {Nat. Lang. Eng.},
  volume = {28},
