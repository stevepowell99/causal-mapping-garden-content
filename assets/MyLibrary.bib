@article{nguyen-trungChatGPTThematicAnalysis2025,
  title = {{{ChatGPT}} in Thematic Analysis: {{Can AI}} Become a Research Assistant in Qualitative Research?},
  shorttitle = {{{ChatGPT}} in Thematic Analysis},
  author = {Nguyen-Trung, Kien},
