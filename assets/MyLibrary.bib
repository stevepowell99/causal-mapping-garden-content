@article{lawrenceGlobalPolycrisisCausal2024,
  title = {Global Polycrisis: The Causal Mechanisms of Crisis Entanglement},
  shorttitle = {Global Polycrisis},
  author = {Lawrence, Michael and Homer-Dixon, Thomas and Janzwood, Scott and Rockstöm, Johan and Renn, Ortwin and Donges, Jonathan F.},
  date = {2024},
  journaltitle = {Glob. Sustain.},
