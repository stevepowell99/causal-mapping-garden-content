@article{schmittCausalMechanismClaim2020,
  title = {The {{Causal Mechanism Claim}} in {{Evaluation}}: {{Does}} the {{Prophecy Fulfill}}?},
  author = {Schmitt, Johannes},
  date = {2020},
  journaltitle = {New Directions for Evaluation},
  volume = {2020},
