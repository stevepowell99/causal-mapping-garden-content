@article{dukanovicComparingChatbotsPsychometric2025,
  title = {Comparing Chatbots to Psychometric Tests in Hiring: Reduced Social Desirability Bias, but Lower Predictive Validity},
  shorttitle = {Comparing Chatbots to Psychometric Tests in Hiring},
  author = {Dukanovic, Danilo and Krpan, Dario},
  date = {2025-04-25},
