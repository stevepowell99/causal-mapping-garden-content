@article{douthwaiteOutcomeTrajectoryEvaluation2023,
  title = {Outcome {{Trajectory Evaluation}} ({{OTE}}): {{An Approach}} to {{Tackle Research-for-Development}}’s {{Long-Causal-Chain Problem}}},
