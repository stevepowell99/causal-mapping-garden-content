@article{nonneckeDevCAFE10Participatory2015,
  title = {{{DevCAFE}} 1.0: {{A}} Participatory Platform for Assessing Development Initiatives in the Field},
  author = {Nonnecke, Brandie and Krishnan, Sanjay and Patel, Jay and Zhou, Mo and Byaruhanga, Laura and Masinde, Dorothy and Meneses, Maria Elena and Del Campo, Alejandro Martin and Crittenden, Camille and Goldberg, Ken},
