  author = {Mumba, Chisoni and Phiri, Davies and Kabbudula, Exillia and Gondwe, Laila and Mebelo, Noanga and Simweene, Gubula and Hankolwe, Mutinta N. and Besa, Kezzy and Sichone, Suwilanji S. and Kayula, Mwila and Geoffrey, Mainda and Fredrick, Kivaria M. and Bebay, Charles and Baba, Soumare and Jesse, Mtui-Malamsha N. and Filippini, Suze P. and Makungu, Chitwambi},
  date = {2025-05-08},
  journaltitle = {PLOS Neglected Tropical Diseases},
